<!DOCTYPE html>
<html>
<head>
  <title>Commands | Hellz Bot</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <h2>🧾 Available Commands</h2>
    <ul>
      <% commands.forEach(cmd => { %>
        <li>+<%= cmd %></li>
      <% }) %>
    </ul>
    <a href="/" class="btn">⬅️ Back</a>
  </div>
</body>
</html>

