<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hellz Bot Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <header>
      <img src="/images/hellz.gif" alt="Hellz Bot Logo" class="logo">
      <h1>🔥 Hellz Bot Dashboard</h1>
      <p>Your all-in-one Discord assistant — moderation, fun & style 😎</p>
      <a href="https://discord.gg/hellz" class="invite-btn">Join the Hellz Community</a>
    </header>

    <main>
      <section class="info">
        <h2>Bot Status</h2>
        <p>✅ Online and running smoothly on <strong>Render</strong>.</p>
        <p>Made with ❤️ by <strong>X1LLZ</strong></p>
      </section>

      <section class="commands">
        <h2>Available Commands</h2>
        <ul>
          <% commands.forEach(cmd => { %>
            <li><strong>+<%= cmd.name %></strong> — <%= cmd.description || "No description provided." %></li>
          <% }) %>
        </ul>
      </section>
    </main>
  </div>
</body>
</html>
