body {
  background-color: #0d0f12;
  color: white;
  font-family: 'Poppins', sans-serif;
  text-align: center;
  margin: 0;
  padding: 0;
}
.container {
  margin-top: 100px;
}
.btn {
  display: inline-block;
  padding: 12px 24px;
  background: #5865F2;
  color: white;
  border-radius: 8px;
  text-decoration: none;
  margin: 8px;
  transition: 0.3s;
}
.btn:hover {
  background: #4752C4;
}
footer {
  margin-top: 80px;
  font-size: 14px;
  color: #aaa;
}
